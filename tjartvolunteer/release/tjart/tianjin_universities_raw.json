  "comprehensive_score_formula": {
    "2025": "综合分 = 文化总分 × 50% + 专业统考成绩 × 2.5 × 50%",
    "note": "文化课满分750分，专业课满分300分。文化课和专业课各占50%权重，专业课乘以2.5换算为750分制",
    "example": "文化课380分 + 专业课220分 = 380×0.5 + 220×2.5×0.5 = 190 + 275 = 465分",
    "source": "https://www.163.com/dy/article/KH0GIBI30556IUES.html"
  },
